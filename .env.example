# ── Base de données ───────────────────────────────────────────────────────────
DB_DATABASE=nexus_noir
DB_USERNAME=nexus_noir
DB_PASSWORD=changeme
DB_PORT=5434

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── API Laravel ───────────────────────────────────────────────────────────────
APP_KEY=                        # php artisan key:generate --show
APP_URL=https://api.nexus-noir.neeo-home.ch
API_PORT=8000

SANCTUM_STATEFUL_DOMAINS=nexus-noir.neeo-home.ch,www.nexus-noir.neeo-home.ch
SESSION_DOMAIN=.nexus-noir.neeo-home.ch

# Stockage : local (dev) ou s3 (prod)
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_ENDPOINT=

# ── Frontend Next.js ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://nexus-noir.neeo-home.ch
NEXT_PUBLIC_API_URL=https://api.nexus-noir.neeo-home.ch/api/v1
WEB_PORT=3000
